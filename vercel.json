{
  "buildCommand": "npm run build",
  "outputDirectory": "dist/music-wishlist-v2/browser",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/:path*" },
    { "source": "/:path((?!.*\\.(?:js|css|woff|ttf|otf|svg|png|jpg|gif|ico|json|map)).*)", "destination": "/index.html" }
  ]
}
