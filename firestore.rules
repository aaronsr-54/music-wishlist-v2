rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /wishlist/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /favorite-artists/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /wishlist-invites/{document=**} {
      allow read: if request.auth != null && (
        request.auth.token.email == resource.data.invitedEmail ||
        request.auth.uid == resource.data.wishlistOwnerId
      );
      allow create: if request.auth != null && request.auth.uid == request.resource.data.wishlistOwnerId;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.wishlistOwnerId ||
        request.auth.token.email == resource.data.invitedEmail
      );
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
