# Firebase config (reemplaza con los tuyos)
FIREBASE_API_KEY=your_api_key_here
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_sender_id
FIREBASE_APP_ID=your_app_id

# Web Push VAPID (para push notifications)
VAPID_SUBJECT=mailto:hello@musicwishlist.app
VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key

# Service Account Firebase (para enviar notificaciones push a otros usuarios)
# Crea una cuenta de servicio en Firebase Console > Project Settings > Service Accounts
# y genera una nueva clave privada JSON. Extrae client_email y private_key.
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"